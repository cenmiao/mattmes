{"event":"tool_call","level":"info","message":"tool_call","params":{"sql":"CREATE TABLE IF NOT EXISTS sys_user (\n    id BIGINT AUTO_INCREMENT PRIMARY KEY,\n    user_no VARCHAR(50) NOT NULL UNIQUE COMMENT '工号',\n    password VARCHAR(255) NOT NULL COMMENT '密码',\n    name VARCHAR(100) NOT NULL COMMENT '姓名',\n    phone VARCHAR(20) COMMENT '手机号',\n    email VARCHAR(100) COMMENT '邮箱',\n    status INT DEFAULT 1 COMMENT '状态：1=启用，0=禁用',\n    disable_reason VARCHAR(50) COMMENT '禁用原因',\n    password_update_time DATETIME COMMENT '密码最后修改时间',\n    login_error_count INT DEFAULT 0 COMMENT '连续登录错误次数',\n    lock_time DATETIME COMMENT '锁定截止时间',\n    last_login_time DATETIME COMMENT '最后登录时间',\n    current_token VARCHAR(500) COMMENT '当前登录Token',\n    token_expire_time DATETIME COMMENT 'Token过期时间',\n    created_by BIGINT COMMENT '创建人',\n    create_time DATETIME DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',\n    updated_by BIGINT COMMENT '更新人',\n    update_time DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',\n    deleted INT DEFAULT 0 COMMENT '逻辑删除标记'\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='用户表'"},"result":{"duration":11,"success":true},"timestamp":"2026-05-31T19:13:54.312+08:00","tool":"execute_sql"}
